{
  "name": "@dot-stbl/regent",
  "version": "0.2.0",
  "description": "Multi-mode static analysis framework for LLM agents — detect + fix rules, no bundled language packs",
  "license": "MIT",
  "type": "module",
  "bin": {
    "regent": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src/reporter",
    "examples",
    "README.md",
    "LICENSE",
    "assets"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bun run build && node dist/cli.js check --help"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "cosmiconfig": "^9.0.2",
    "dotenv": "^17.4.2",
    "picocolors": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "re2-wasm": "^1.0.0",
    "simple-git": "^3.27.0",
    "tinyglobby": "^0.2.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.1.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dot-stbl/regent.git"
  },
  "bugs": {
    "url": "https://github.com/dot-stbl/regent/issues"
  },
  "keywords": [
    "linter",
    "rules",
    "static-analysis",
    "grep",
    "regex",
    "stbl"
  ],
  "homepage": "https://github.com/dot-stbl/regent#readme"
}
