{
  "name": "@dot-stbl/regent",
  "version": "0.3.0",
  "description": "Multi-mode static analysis framework for LLM agents — regex + AST rules over bundled language grammars (C#, TypeScript, Rust, Go)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "regent": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "assets/llm",
    "examples",
    "skills",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "bun run build && node dist/cli.js check --help"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@ast-grep/lang-csharp": "^0.0.6",
    "@ast-grep/lang-go": "^0.0.6",
    "@ast-grep/lang-rust": "^0.0.7",
    "@ast-grep/lang-typescript": "^0.0.7",
    "@ast-grep/napi": "^0.44.1",
    "chokidar": "^4.0.0",
    "commander": "^15.0.0",
    "cosmiconfig": "^9.0.2",
    "dotenv": "^17.4.2",
    "js-yaml": "^4.1.0",
    "picocolors": "^1.1.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "re2-wasm": "^1.0.0",
    "simple-git": "^3.27.0",
    "tinyglobby": "^0.2.0",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^26.1.1",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dot-stbl/regent.git"
  },
  "bugs": {
    "url": "https://github.com/dot-stbl/regent/issues"
  },
  "keywords": [
    "linter",
    "rules",
    "static-analysis",
    "grep",
    "regex",
    "stbl"
  ],
  "homepage": "https://github.com/dot-stbl/regent#readme",
  "trustedDependencies": [
    "@ast-grep/lang-csharp",
    "@ast-grep/lang-go",
    "@ast-grep/lang-rust",
    "@ast-grep/lang-typescript"
  ]
}
